<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-fullscreen">
<meta name="apple-mobile-web-app-title" content="INVINCIBLE">
<meta name="theme-color" content="#0a0a0f">
<title>INVINCIBLE SURVIVORS</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@500;700&display=swap');
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;user-select:none}
  html,body{width:100%;height:100%;overflow:hidden;background:#0a0a0f;font-family:'Rajdhani',sans-serif;touch-action:none}
  canvas{display:block;position:absolute;top:0;left:0}
  #ui{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:10}
  #screen{position:absolute;top:0;left:0;width:100%;height:100%;z-index:20;display:flex;flex-direction:column;align-items:center;justify-content:center}
  .bebas{font-family:'Bebas Neue',sans-serif}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}
  @keyframes popIn{from{transform:scale(.5);opacity:0}to{transform:scale(1);opacity:1}}
  @keyframes fadeUp{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}
  @keyframes shake{0%,100%{transform:translate(0)}20%{transform:translate(-6px,3px)}40%{transform:translate(6px,-3px)}60%{transform:translate(-4px,4px)}80%{transform:translate(4px,-2px)}}
  @keyframes floatUp{0%{transform:translateY(0);opacity:1}100%{transform:translateY(-60px);opacity:0}}
  .btn{background:linear-gradient(135deg,#1a1a2e,#16213e);border:2px solid;border-radius:8px;color:#fff;font-family:'Bebas Neue';font-size:22px;letter-spacing:3px;padding:14px 36px;cursor:pointer;transition:transform .1s,box-shadow .1s;pointer-events:all}
  .btn:active{transform:scale(.94)}
  .char-card{background:linear-gradient(135deg,#0d1117,#161b22);border:2px solid;border-radius:12px;padding:16px;cursor:pointer;transition:all .15s;pointer-events:all;text-align:center;min-width:140px}
  .char-card:active{transform:scale(.95)}
  .char-card.selected{transform:scale(1.04)}
  #hud-top{position:absolute;top:0;left:0;right:0;padding:10px 14px;display:flex;justify-content:space-between;align-items:flex-start;pointer-events:none}
  #hud-bot{position:absolute;bottom:0;left:0;right:0;padding:0 14px 14px;display:flex;justify-content:flex-end;align-items:flex-end;pointer-events:none}
  #joystick-zone{position:absolute;bottom:20px;left:20px;width:130px;height:130px;pointer-events:all;z-index:15}
  #joystick-base{width:130px;height:130px;border-radius:50%;background:rgba(255,255,255,.06);border:2px solid rgba(255,255,255,.12);position:absolute}
  #joystick-knob{width:54px;height:54px;border-radius:50%;background:rgba(255,255,255,.2);border:2px solid rgba(255,255,255,.4);position:absolute;top:38px;left:38px;transition:background .1s}
  .hpbar{height:8px;border-radius:4px;background:#1a1a2e;overflow:hidden;width:100%}
  .hpbar-fill{height:100%;border-radius:4px;transition:width .2s}
  .wavebar{height:5px;border-radius:3px;background:#1a1a2e;overflow:hidden;width:100%}
  .wavebar-fill{height:100%;border-radius:3px;transition:width .3s linear}
  #dmg-overlay{position:absolute;inset:0;pointer-events:none;border-radius:0;opacity:0;background:radial-gradient(ellipse at center,transparent 40%,#ff000060 100%);transition:opacity .1s;z-index:9}
</style>
</head>
<body>
<canvas id="c"></canvas>
<div id="dmg-overlay"></div>
<div id="ui">
  <div id="hud-top" style="display:none">
    <div style="flex:1">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:4px">
        <span id="hud-emoji" style="font-size:18px"></span>
        <span id="hud-name" class="bebas" style="font-size:18px;letter-spacing:2px;color:#fff"></span>
      </div>
      <div class="hpbar" style="width:160px"><div id="hp-fill" class="hpbar-fill" style="background:#ff2244"></div></div>
      <div style="font-size:11px;color:#5a7090;margin-top:2px"><span id="hp-text"></span></div>
    </div>
    <div style="text-align:right">
      <div class="bebas" style="font-size:28px;color:#ffcc00;letter-spacing:2px" id="hud-score">0</div>
      <div style="font-size:11px;color:#5a7090;letter-spacing:2px">WAVE <span id="hud-wave">1</span></div>
      <div class="wavebar" style="width:100px;margin-top:3px;margin-left:auto"><div id="wave-fill" class="wavebar-fill" style="background:#4488ff"></div></div>
    </div>
  </div>
</div>
<div id="joystick-zone" style="display:none">
  <div id="joystick-base"></div>
  <div id="joystick-knob"></div>
</div>
<div id="screen"></div>

<script>
// ═══════════════════════════════════════════════════════════
//  INVINCIBLE SURVIVORS  — Full game
// ═══════════════════════════════════════════════════════════

const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');
const screen = document.getElementById('screen');
const hudTop = document.getElementById('hud-top');
const joyZone = document.getElementById('joystick-zone');
const dmgOverlay = document.getElementById('dmg-overlay');

let W, H;
function resize(){
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
resize();
window.addEventListener('resize', resize);

// ── CHARACTERS ──────────────────────────────────────────────
const CHARS = [
  {
    id:'mark', name:'INVINCIBLE', emoji:'🔵', color:'#2299ff', accent:'#ffcc00',
    desc:'Balanced hero. Gets stronger as HP drops.',
    hp:120, spd:2.8, dmg:18, atkSpd:1.0, range:180, armor:0,
    special:'RAGE MODE',
    specialDesc:'Damage doubles below 40% HP',
    specialFn(p){ return p.hp/p.maxHp < 0.4 ? 2 : 1; }
  },
  {
    id:'omni', name:'OMNI-MAN', emoji:'🔴', color:'#ff2233', accent:'#ff8800',
    desc:'Pure destruction. Massive AoE punches.',
    hp:160, spd:2.2, dmg:35, atkSpd:0.6, range:120, armor:2,
    special:'VILTRUMITE FURY',
    specialDesc:'Every 5th hit is a shockwave hitting all nearby',
    specialFn(p){ return 1; }
  },
  {
    id:'eve', name:'ATOM EVE', emoji:'🟣', color:'#dd44ff', accent:'#ff88ff',
    desc:'Matter manipulation. Long range blasts + shields.',
    hp:90, spd:3.0, dmg:14, atkSpd:1.4, range:260, armor:0,
    special:'MATTER SHIELD',
    specialDesc:'Periodically absorbs one hit every 8s',
    specialFn(p){ return 1; }
  },
  {
    id:'rex', name:'REX SPLODE', emoji:'🟢', color:'#44ff88', accent:'#ffcc00',
    desc:'Explosive projectiles. High crit chance.',
    hp:100, spd:2.9, dmg:22, atkSpd:0.9, range:200, armor:0,
    special:'CHAIN REACTION',
    specialDesc:'30% chance bullets explode on hit, dealing AoE',
    specialFn(p){ return 1; }
  },
  {
    id:'monster', name:'MONSTER GIRL', emoji:'🟠', color:'#ff8800', accent:'#ff2233',
    desc:'Regenerates HP. Slow but nearly unkillable.',
    hp:200, spd:2.0, dmg:28, atkSpd:0.7, range:100, armor:4,
    special:'REGEN',
    specialDesc:'Heals 1 HP/sec passively',
    specialFn(p){ return 1; }
  },
];

// ── UPGRADES ────────────────────────────────────────────────
const UPGRADE_POOL = [
  {id:'dmg',    name:'POWER UP',      icon:'💥', desc:'+20% damage',       apply(p){p.dmg*=1.2}},
  {id:'spd',    name:'SPEED BOOST',   icon:'⚡', desc:'+15% move speed',   apply(p){p.spd*=1.15}},
  {id:'atk',    name:'RAPID FIRE',    icon:'🔫', desc:'+20% attack speed', apply(p){p.atkSpd*=1.2}},
  {id:'range',  name:'RANGE EXT',     icon:'🎯', desc:'+25% attack range', apply(p){p.range*=1.25}},
  {id:'hp',     name:'VITAL BOOST',   icon:'❤️', desc:'+30 max HP',        apply(p){p.maxHp+=30;p.hp+=30}},
  {id:'heal',   name:'FIELD MEDIC',   icon:'💊', desc:'Restore 40 HP',     apply(p){p.hp=Math.min(p.maxHp,p.hp+40)}},
  {id:'armor',  name:'ARMOR PLATE',   icon:'🛡️', desc:'+2 armor',          apply(p){p.armor+=2}},
  {id:'pierce', name:'PIERCING',      icon:'🔷', desc:'Bullets pierce 1 extra enemy', apply(p){p.pierce=(p.pierce||0)+1}},
  {id:'multi',  name:'MULTISHOT',     icon:'🌟', desc:'+1 projectile',     apply(p){p.multishot=(p.multishot||1)+1}},
  {id:'xpup',   name:'EXPERIENCE',    icon:'📚', desc:'+30% XP gain',      apply(p){p.xpMult=(p.xpMult||1)*1.3}},
];

// ── GAME STATE ───────────────────────────────────────────────
let G = {};

function initGame(charId){
  const ch = CHARS.find(c=>c.id===charId);
  G = {
    state:'playing', // playing | upgrade | boss_intro | dead
    char: ch,
    player:{
      x: 0, y: 0,
      hp: ch.hp, maxHp: ch.hp,
      spd: ch.spd, dmg: ch.dmg, atkSpd: ch.atkSpd,
      range: ch.range, armor: ch.armor,
      pierce: 0, multishot: 1, xpMult: 1,
      atkTimer: 0,
      shieldTimer: 0, shieldActive: false,
      omniCombo: 0,
      regenTimer: 0,
    },
    cam: {x:0, y:0},
    enemies: [],
    bullets: [],
    particles: [],
    xpOrbs: [],
    floaters: [],
    wave: 1,
    waveTimer: 0,
    waveDuration: 25,
    waveEnemyCount: 0,
    waveSpawnTimer: 0,
    score: 0,
    xp: 0,
    xpNeeded: 60,
    level: 1,
    bossActive: false,
    boss: null,
    frameCount: 0,
    pendingUpgrades: [],
    shakeTimer: 0,
  };
  startWave();
}

// ── WAVES & SPAWNING ────────────────────────────────────────
function startWave(){
  const w = G.wave;
  G.waveTimer = 0;
  G.waveDuration = w % 5 === 0 ? 0 : Math.max(18, 28 - w);
  G.waveEnemyBudget = w * 12 + 20;
  G.waveSpawnTimer = 0;
  G.bossActive = (w % 5 === 0);
  if(G.bossActive) spawnBoss();
}

function spawnEnemy(isBoss=false){
  const w = G.wave;
  const angle = Math.random() * Math.PI * 2;
  const dist = Math.max(W,H) * 0.6 + 60;
  const x = G.player.x + Math.cos(angle)*dist;
  const y = G.player.y + Math.sin(angle)*dist;
  const types = ['grunt','tank','speeder','shooter'];
  const weights = [50,20,25,5];
  let roll = Math.random()*100, type='grunt';
  let acc=0;
  for(let i=0;i<types.length;i++){acc+=weights[i];if(roll<acc){type=types[i];break;}}

  const scale = 1 + w*0.04;
  const base = {
    grunt:   {hp:20+w*4,   spd:1.2+w*.06, dmg:8+w,   size:14, color:'#ff4444', emoji:'👾'},
    tank:    {hp:60+w*12,  spd:0.7+w*.03, dmg:15+w*2,size:20, color:'#aa2222', emoji:'🤖'},
    speeder: {hp:12+w*3,   spd:2.2+w*.1,  dmg:6+w,   size:11, color:'#ff8800', emoji:'💨'},
    shooter: {hp:25+w*5,   spd:0.9+w*.04, dmg:10+w*2,size:13, color:'#aa44ff', emoji:'🔮'},
  };
  const b = base[type];
  G.enemies.push({
    x, y, type,
    hp: Math.round(b.hp*scale), maxHp: Math.round(b.hp*scale),
    spd: b.spd, dmg: b.dmg, size: b.size,
    color: b.color, emoji: b.emoji,
    shootTimer: type==='shooter' ? Math.random()*3 : 0,
    knockX:0, knockY:0,
    flashTimer:0,
  });
}

function spawnBoss(){
  const w = G.wave;
  const bossTypes = [
    {name:'VILTRUMITE WARRIOR', color:'#ff2244', size:44, hp:400+w*80, dmg:25+w*5, spd:1.4, emoji:'👹', phase:false},
    {name:'SEQUID HIVE MIND',   color:'#44ff88', size:40, hp:300+w*60, dmg:18+w*4, spd:1.0, emoji:'🦑', phase:true},
    {name:'BATTLE BEAST',       color:'#ff8800', size:48, hp:500+w*100,dmg:30+w*6, spd:1.6, emoji:'🐯', phase:false},
  ];
  const bt = bossTypes[(Math.floor(w/5)-1) % bossTypes.length];
  const angle = Math.random()*Math.PI*2;
  const dist = Math.max(W,H)*0.55;
  G.boss = {
    ...bt,
    x: G.player.x + Math.cos(angle)*dist,
    y: G.player.y + Math.sin(angle)*dist,
    maxHp: bt.hp, hp: bt.hp,
    shootTimer:0,
    flashTimer:0,
    knockX:0, knockY:0,
    phaseActive: false,
    phaseTimer:0,
  };
  showBossIntro(bt.name);
}

// ── SHOOTING ─────────────────────────────────────────────────
function playerShoot(){
  const p = G.player;
  const ch = G.char;
  let target = findNearestEnemy();
  if(!target) return;
  const dx = target.x - p.x, dy = target.y - p.y;
  const len = Math.hypot(dx,dy);
  const nx = dx/len, ny = dy/len;

  const shots = p.multishot || 1;
  const spread = (shots-1) * 0.15;
  for(let i=0;i<shots;i++){
    const offset = shots>1 ? -spread/2 + (spread/(shots-1))*i : 0;
    const angle = Math.atan2(ny,nx) + offset;
    const dmgMult = ch.specialFn ? ch.specialFn(p) : 1;
    G.bullets.push({
      x: p.x, y: p.y,
      vx: Math.cos(angle)*9,
      vy: Math.sin(angle)*9,
      dmg: Math.round(p.dmg * dmgMult),
      range: p.range,
      traveled: 0,
      pierce: p.pierce||0,
      hitsLeft: (p.pierce||0)+1,
      owner:'player',
      color: ch.color,
      size: 5,
      isRex: ch.id==='rex',
      isOmni: ch.id==='omni',
    });
  }
  // Omni-Man shockwave every 5th shot
  if(ch.id==='omni'){
    p.omniCombo = (p.omniCombo||0)+1;
    if(p.omniCombo>=5){
      p.omniCombo=0;
      shockwave(p.x, p.y, 140, p.dmg*2, '#ff4400');
    }
  }
}

function enemyShoot(e){
  const dx = G.player.x-e.x, dy=G.player.y-e.y;
  const len = Math.hypot(dx,dy);
  G.bullets.push({
    x:e.x,y:e.y,
    vx:(dx/len)*4.5, vy:(dy/len)*4.5,
    dmg: e.dmg, traveled:0, range:300,
    hitsLeft:1, owner:'enemy',
    color:'#ff0000', size:5,
  });
}

function shockwave(x,y,r,dmg,color){
  G.enemies.forEach(e=>{
    const d = Math.hypot(e.x-x,e.y-y);
    if(d<r){
      const mult = 1-(d/r)*0.5;
      damageEnemy(e, Math.round(dmg*mult));
      e.knockX += (e.x-x)/d*8;
      e.knockY += (e.y-y)/d*8;
    }
  });
  // visual ring
  for(let i=0;i<24;i++){
    const a = (i/24)*Math.PI*2;
    G.particles.push({x,y,vx:Math.cos(a)*6,vy:Math.sin(a)*6,life:1,maxLife:1,color,size:4,type:'spark'});
  }
}

function findNearestEnemy(){
  let best=null, bestD=Infinity;
  const targets = G.bossActive&&G.boss ? [G.boss,...G.enemies] : G.enemies;
  targets.forEach(e=>{
    if(!e) return;
    const d=Math.hypot(e.x-G.player.x,e.y-G.player.y);
    if(d<bestD&&d<(G.player.range)){bestD=d;best=e;}
  });
  return best;
}

function damageEnemy(e, dmg){
  e.hp -= dmg;
  e.flashTimer = 6;
  spawnFloater(e.x, e.y, '-'+dmg, '#fff');
  if(e.hp<=0){
    const xp = e.size || 10;
    spawnXpOrb(e.x,e.y, Math.round(xp * (G.player.xpMult||1)));
    spawnBurst(e.x,e.y,e.color);
    G.score += (e.maxHp||20);
  }
}

// ── MAIN LOOP ────────────────────────────────────────────────
let lastTime=0;
function loop(ts){
  const dt = Math.min((ts-lastTime)/1000,0.05);
  lastTime=ts;
  if(G.state==='playing') update(dt);
  draw();
  requestAnimationFrame(loop);
}

function update(dt){
  const p = G.player;
  const ch = G.char;
  G.frameCount++;

  // Joystick movement
  const jx = joystickDir.x, jy = joystickDir.y;
  if(jx!==0||jy!==0){
    p.x += jx*p.spd*60*dt;
    p.y += jy*p.spd*60*dt;
  }

  // Monster Girl regen
  if(ch.id==='monster'){
    p.regenTimer=(p.regenTimer||0)+dt;
    if(p.regenTimer>=1){p.regenTimer=0;p.hp=Math.min(p.maxHp,p.hp+1);}
  }

  // Atom Eve shield
  if(ch.id==='eve'){
    if(!p.shieldActive){
      p.shieldTimer=(p.shieldTimer||0)+dt;
      if(p.shieldTimer>=8){p.shieldTimer=0;p.shieldActive=true;}
    }
  }

  // Camera follow
  G.cam.x += (p.x - G.cam.x)*0.12;
  G.cam.y += (p.y - G.cam.y)*0.12;

  // Auto attack
  p.atkTimer -= dt;
  if(p.atkTimer<=0){
    playerShoot();
    p.atkTimer = 1/p.atkSpd;
  }

  // Wave timer
  if(!G.bossActive){
    G.waveTimer += dt;
    // Spawn enemies
    G.waveSpawnTimer-=dt;
    if(G.waveSpawnTimer<=0&&G.waveEnemyBudget>0){
      const count = Math.min(3+Math.floor(G.wave/3), 6);
      for(let i=0;i<count;i++) if(G.waveEnemyBudget-->0) spawnEnemy();
      G.waveSpawnTimer = Math.max(0.5, 2.2-G.wave*0.08);
    }
    if(G.waveTimer>=G.waveDuration&&G.enemies.length===0){
      nextWave();
    }
  }

  // Move bullets
  for(let i=G.bullets.length-1;i>=0;i--){
    const b=G.bullets[i];
    b.x+=b.vx; b.y+=b.vy;
    b.traveled+=Math.hypot(b.vx,b.vy);
    if(b.traveled>b.range||b.hitsLeft<=0){G.bullets.splice(i,1);continue;}

    if(b.owner==='player'){
      // Hit enemies
      const targets = G.bossActive&&G.boss ? [G.boss,...G.enemies] : G.enemies;
      for(let j=targets.length-1;j>=0;j--){
        const e=targets[j];
        if(!e) continue;
        if(Math.hypot(b.x-e.x,b.y-e.y)<e.size+b.size){
          // Rex explode
          if(b.isRex && Math.random()<0.3){
            shockwave(b.x,b.y,70,b.dmg*0.8,'#ffcc00');
            spawnBurst(b.x,b.y,'#ffcc00');
          }
          damageEnemy(e,b.dmg);
          b.hitsLeft--;
          if(b.hitsLeft<=0) break;
        }
      }
    } else {
      // Enemy bullet hits player
      if(Math.hypot(b.x-p.x,b.y-p.y)<18){
        if(p.shieldActive){
          p.shieldActive=false;
          spawnFloater(p.x,p.y,'BLOCKED!','#44ffff');
          spawnBurst(p.x,p.y,'#44ffff');
        } else {
          const dmg=Math.max(1,b.dmg-p.armor);
          p.hp=Math.max(0,p.hp-dmg);
          G.shakeTimer=8;
          flashDamage();
          spawnFloater(p.x,p.y-20,'-'+dmg,'#ff4444');
          if(p.hp<=0){G.state='dead';showDead();}
        }
        G.bullets.splice(i,1);
      }
    }
  }

  // Move enemies
  for(let i=G.enemies.length-1;i>=0;i--){
    const e=G.enemies[i];
    e.flashTimer=Math.max(0,e.flashTimer-1);
    e.knockX*=0.85; e.knockY*=0.85;
    const dx=p.x-e.x, dy=p.y-e.y;
    const d=Math.hypot(dx,dy);
    if(d>1){
      e.x+=((dx/d)*e.spd + e.knockX)*60*dt;
      e.y+=((dy/d)*e.spd + e.knockY)*60*dt;
    }
    // Shooter shoots
    if(e.type==='shooter'){
      e.shootTimer-=dt;
      if(e.shootTimer<=0&&d<350){enemyShoot(e);e.shootTimer=2.5;}
    }
    // Touch player
    if(d<22&&!p.invincTimer){
      const dmg=Math.max(1,e.dmg-p.armor);
      p.hp=Math.max(0,p.hp-dmg);
      G.shakeTimer=8;
      flashDamage();
      e.knockX=(e.x-p.x)/d*10; e.knockY=(e.y-p.y)/d*10;
      p.invincTimer=0.4;
      if(p.hp<=0){G.state='dead';showDead();}
    }
    if(e.hp<=0) G.enemies.splice(i,1);
  }
  if(p.invincTimer>0) p.invincTimer-=dt;

  // Boss
  if(G.bossActive&&G.boss){
    const bo=G.boss;
    bo.flashTimer=Math.max(0,bo.flashTimer-1);
    bo.knockX*=0.9; bo.knockY*=0.9;
    const dx=p.x-bo.x, dy=p.y-bo.y;
    const d=Math.hypot(dx,dy);
    bo.x+=(dx/d*bo.spd+bo.knockX)*60*dt;
    bo.y+=(dy/d*bo.spd+bo.knockY)*60*dt;
    bo.shootTimer-=dt;
    if(bo.shootTimer<=0){
      // Multi-shot
      for(let a=0;a<5;a++){
        const ang=Math.atan2(dy,dx)+(a-2)*0.3;
        G.bullets.push({x:bo.x,y:bo.y,vx:Math.cos(ang)*5,vy:Math.sin(ang)*5,dmg:bo.dmg,traveled:0,range:350,hitsLeft:1,owner:'enemy',color:'#ff2244',size:7});
      }
      bo.shootTimer=1.8;
    }
    if(d<50){
      const dmg=Math.max(1,bo.dmg*2-p.armor);
      p.hp=Math.max(0,p.hp-dmg);
      G.shakeTimer=12; flashDamage();
      if(p.hp<=0){G.state='dead';showDead();}
    }
    // Hit boss with player bullets
    for(let i=G.bullets.length-1;i>=0;i--){
      const b=G.bullets[i];
      if(b.owner!=='player') continue;
      if(Math.hypot(b.x-bo.x,b.y-bo.y)<bo.size+b.size){
        if(b.isRex&&Math.random()<0.3) shockwave(b.x,b.y,80,b.dmg*0.8,'#ffcc00');
        bo.hp-=b.dmg;
        bo.flashTimer=6;
        spawnFloater(bo.x,bo.y,'-'+b.dmg,'#fff');
        b.hitsLeft--;
        if(b.hitsLeft<=0) G.bullets.splice(i,1);
        if(bo.hp<=0){
          G.score+=bo.maxHp*5;
          spawnXpOrb(bo.x,bo.y,80);
          spawnBurst(bo.x,bo.y,bo.color,40);
          G.bossActive=false; G.boss=null;
          nextWave();
          return;
        }
      }
    }
  }

  // XP orbs
  for(let i=G.xpOrbs.length-1;i>=0;i--){
    const o=G.xpOrbs[i];
    const dx=p.x-o.x, dy=p.y-o.y;
    const d=Math.hypot(dx,dy);
    if(d<120){o.x+=dx/d*5;o.y+=dy/d*5;}
    if(d<16){
      G.xp+=o.val;
      G.xpOrbs.splice(i,1);
      if(G.xp>=G.xpNeeded) levelUp();
    }
  }

  // Particles
  for(let i=G.particles.length-1;i>=0;i--){
    const p=G.particles[i];
    p.x+=p.vx; p.y+=p.vy;
    p.vx*=0.92; p.vy*=0.92;
    p.life-=0.04;
    if(p.life<=0) G.particles.splice(i,1);
  }

  // Floaters
  for(let i=G.floaters.length-1;i>=0;i--){
    const f=G.floaters[i];
    f.y-=1.2; f.life-=0.035;
    if(f.life<=0) G.floaters.splice(i,1);
  }

  if(G.shakeTimer>0) G.shakeTimer--;

  updateHUD();
}

// ── DRAW ─────────────────────────────────────────────────────
function draw(){
  ctx.clearRect(0,0,W,H);

  // shake
  let sx=0,sy=0;
  if(G.shakeTimer>0){sx=(Math.random()-.5)*6;sy=(Math.random()-.5)*6;}

  ctx.save();
  ctx.translate(W/2-G.cam.x+sx, H/2-G.cam.y+sy);

  // Background grid
  drawGrid();

  // XP orbs
  G.xpOrbs.forEach(o=>{
    ctx.beginPath();
    ctx.arc(o.x,o.y,5,0,Math.PI*2);
    ctx.fillStyle=o.color;
    ctx.fill();
    ctx.beginPath();
    ctx.arc(o.x,o.y,8,0,Math.PI*2);
    ctx.strokeStyle=o.color+'66';
    ctx.lineWidth=2;
    ctx.stroke();
  });

  // Bullets
  G.bullets.forEach(b=>{
    ctx.save();
    ctx.shadowBlur=10;
    ctx.shadowColor=b.color;
    ctx.beginPath();
    ctx.arc(b.x,b.y,b.size,0,Math.PI*2);
    ctx.fillStyle=b.color;
    ctx.fill();
    ctx.restore();
  });

  // Enemies
  G.enemies.forEach(e=>drawEnemy(e));

  // Boss
  if(G.bossActive&&G.boss) drawBoss(G.boss);

  // Particles
  G.particles.forEach(p=>{
    ctx.globalAlpha=p.life;
    ctx.beginPath();
    ctx.arc(p.x,p.y,p.size||3,0,Math.PI*2);
    ctx.fillStyle=p.color;
    ctx.fill();
  });
  ctx.globalAlpha=1;

  // Player
  drawPlayer();

  // Floaters
  G.floaters.forEach(f=>{
    ctx.globalAlpha=f.life;
    ctx.font=`bold 13px Rajdhani`;
    ctx.fillStyle=f.color;
    ctx.textAlign='center';
    ctx.fillText(f.text,f.x,f.y);
  });
  ctx.globalAlpha=1;

  ctx.restore();

  // XP bar
  if(G.state==='playing'){
    const xpPct = G.xp/G.xpNeeded;
    ctx.fillStyle='#1a1a2e';
    ctx.fillRect(0,H-6,W,6);
    ctx.fillStyle='#8844ff';
    ctx.fillRect(0,H-6,W*xpPct,6);

    // Level
    ctx.font='bold 11px Rajdhani';
    ctx.fillStyle='#8844ff';
    ctx.textAlign='right';
    ctx.fillText('LV '+G.level, W-8, H-10);
  }
}

function drawGrid(){
  const gs=80;
  const ox=((G.cam.x%gs)+gs)%gs;
  const oy=((G.cam.y%gs)+gs)%gs;
  ctx.strokeStyle='rgba(40,60,100,0.35)';
  ctx.lineWidth=1;
  for(let x=-ox-W/2;x<W;x+=gs){
    ctx.beginPath();ctx.moveTo(x,-(H));ctx.lineTo(x,H);ctx.stroke();
  }
  for(let y=-oy-H/2;y<H;y+=gs){
    ctx.beginPath();ctx.moveTo(-W,y);ctx.lineTo(W,y);ctx.stroke();
  }
}

function drawPlayer(){
  const p=G.player;
  const ch=G.char;
  const t=G.frameCount;

  // Shield ring
  if(p.shieldActive){
    ctx.save();
    ctx.shadowBlur=20;ctx.shadowColor='#44ffff';
    ctx.beginPath();ctx.arc(p.x,p.y,28,0,Math.PI*2);
    ctx.strokeStyle='#44ffff';ctx.lineWidth=3;
    ctx.globalAlpha=0.6+Math.sin(t*0.2)*0.3;
    ctx.stroke();ctx.restore();
  }

  // Glow
  ctx.save();
  ctx.shadowBlur=24;ctx.shadowColor=ch.color;
  ctx.beginPath();ctx.arc(p.x,p.y,18,0,Math.PI*2);
  ctx.fillStyle=ch.color+'33';ctx.fill();
  ctx.restore();

  // Body
  ctx.save();
  ctx.shadowBlur=8;ctx.shadowColor=ch.color;
  ctx.fillStyle=ch.color;
  // Cape-ish shape
  ctx.beginPath();
  ctx.arc(p.x,p.y,16,0,Math.PI*2);
  ctx.fill();
  ctx.fillStyle='#fff';
  ctx.font='22px serif';
  ctx.textAlign='center';
  ctx.textBaseline='middle';
  ctx.fillText(ch.emoji,p.x,p.y);
  ctx.restore();
}

function drawEnemy(e){
  ctx.save();
  if(e.flashTimer>0) ctx.globalAlpha = e.flashTimer%2===0?0.4:1;
  ctx.shadowBlur=8;ctx.shadowColor=e.color;
  ctx.beginPath();ctx.arc(e.x,e.y,e.size,0,Math.PI*2);
  ctx.fillStyle=e.color+'44';ctx.fill();
  ctx.font=`${e.size+6}px serif`;
  ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.fillText(e.emoji,e.x,e.y);
  // HP bar
  if(e.hp<e.maxHp){
    const bw=e.size*2.5;
    ctx.fillStyle='#333';
    ctx.fillRect(e.x-bw/2,e.y-e.size-8,bw,4);
    ctx.fillStyle='#ff2244';
    ctx.fillRect(e.x-bw/2,e.y-e.size-8,bw*(e.hp/e.maxHp),4);
  }
  ctx.restore();
}

function drawBoss(b){
  ctx.save();
  const pulse=Math.sin(G.frameCount*0.08)*0.2;
  if(b.flashTimer>0) ctx.globalAlpha=b.flashTimer%2===0?0.4:1;
  ctx.shadowBlur=30+pulse*10;ctx.shadowColor=b.color;
  ctx.beginPath();ctx.arc(b.x,b.y,b.size,0,Math.PI*2);
  ctx.fillStyle=b.color+'33';ctx.fill();
  ctx.strokeStyle=b.color;ctx.lineWidth=3;ctx.stroke();
  ctx.font=`${b.size+10}px serif`;
  ctx.textAlign='center';ctx.textBaseline='middle';
  ctx.fillText(b.emoji,b.x,b.y);
  // HP bar
  const bw=120;
  ctx.fillStyle='#111';
  ctx.fillRect(b.x-bw/2,b.y-b.size-16,bw,10);
  ctx.fillStyle=b.color;
  ctx.fillRect(b.x-bw/2,b.y-b.size-16,bw*(b.hp/b.maxHp),10);
  ctx.fillStyle='#fff';ctx.font='bold 10px Rajdhani';
  ctx.fillText(b.name, b.x, b.y-b.size-22);
  ctx.restore();
}

// ── EFFECTS ─────────────────────────────────────────────────
function spawnBurst(x,y,color,count=14){
  for(let i=0;i<count;i++){
    const a=Math.random()*Math.PI*2;
    const spd=2+Math.random()*4;
    G.particles.push({x,y,vx:Math.cos(a)*spd,vy:Math.sin(a)*spd,life:1,maxLife:1,color,size:3+Math.random()*3});
  }
}

function spawnXpOrb(x,y,val){
  const colors=['#8844ff','#aa66ff','#cc88ff'];
  const count=Math.min(val,8);
  for(let i=0;i<count;i++){
    G.xpOrbs.push({
      x:x+(Math.random()-.5)*30,
      y:y+(Math.random()-.5)*30,
      val:Math.ceil(val/count),
      color:colors[Math.floor(Math.random()*colors.length)],
    });
  }
}

function spawnFloater(x,y,text,color){
  G.floaters.push({x,y:y-10,text,color,life:1});
}

let dmgFlashTO=null;
function flashDamage(){
  dmgOverlay.style.opacity='0.7';
  if(dmgFlashTO) clearTimeout(dmgFlashTO);
  dmgFlashTO=setTimeout(()=>dmgOverlay.style.opacity='0',120);
}

// ── HUD ──────────────────────────────────────────────────────
function updateHUD(){
  const p=G.player;
  document.getElementById('hud-score').textContent=G.score.toLocaleString();
  document.getElementById('hud-wave').textContent=G.wave;
  document.getElementById('hp-fill').style.width=(p.hp/p.maxHp*100)+'%';
  document.getElementById('hp-text').textContent=Math.ceil(p.hp)+'/'+p.maxHp;
  const wPct = G.bossActive ? (G.boss?(1-G.boss.hp/G.boss.maxHp)*100:100) : (G.waveTimer/G.waveDuration*100);
  document.getElementById('wave-fill').style.width=Math.min(100,wPct)+'%';
  document.getElementById('wave-fill').style.background=G.bossActive?'#ff2244':'#4488ff';
}

// ── LEVEL UP ─────────────────────────────────────────────────
function levelUp(){
  G.xp=0; G.level++;
  G.xpNeeded=Math.round(G.xpNeeded*1.25);
  G.state='upgrade';
  // pick 3 random upgrades
  const pool=[...UPGRADE_POOL].sort(()=>Math.random()-.5).slice(0,3);
  showUpgradeScreen(pool);
}

function nextWave(){
  G.wave++;
  G.enemies=[];
  G.bullets=[];
  showWaveTransition();
}

// ── SCREENS ──────────────────────────────────────────────────
function showMenu(){
  hudTop.style.display='none';
  joyZone.style.display='none';
  screen.innerHTML='';
  screen.style.background='radial-gradient(ellipse at 50% 30%,#0d1f3a,#0a0a0f)';
  screen.style.display='flex';

  const s=document.createElement('div');
  s.style.cssText='text-align:center;padding:20px;max-width:420px;width:100%';
  s.innerHTML=`
    <div style="font-family:'Rajdhani';font-size:12px;letter-spacing:6px;color:#5a7090;margin-bottom:6px">SUPERHERO SURVIVAL</div>
    <div class="bebas" style="font-size:80px;letter-spacing:4px;color:#fff;line-height:1;text-shadow:0 0 40px #2299ff,0 0 80px #2299ff44">INVINCIBLE</div>
    <div class="bebas" style="font-size:32px;letter-spacing:8px;color:#ffcc00;margin-bottom:6px;text-shadow:0 0 20px #ffcc0088">SURVIVORS</div>
    <div style="width:200px;height:2px;background:linear-gradient(to right,transparent,#ff2233,transparent);margin:0 auto 28px"></div>
    <div style="font-size:13px;color:#5a7090;margin-bottom:22px;letter-spacing:1px">CHOOSE YOUR HERO</div>
    <div id="char-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:24px"></div>
    <button id="start-btn" class="btn" style="border-color:#ffcc00;color:#ffcc00;box-shadow:0 0 20px #ffcc0044;width:100%;font-size:24px;display:none" onclick="startGame()">FIGHT →</button>
  `;
  screen.appendChild(s);

  const grid=s.querySelector('#char-grid');
  let selected=null;
  CHARS.forEach(ch=>{
    const card=document.createElement('div');
    card.className='char-card';
    card.style.borderColor=ch.color+'66';
    card.innerHTML=`
      <div style="font-size:32px;margin-bottom:4px">${ch.emoji}</div>
      <div class="bebas" style="font-size:16px;color:${ch.color};letter-spacing:2px">${ch.name}</div>
      <div style="font-size:10px;color:#5a7090;margin-bottom:6px">${ch.desc}</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:2px;font-size:10px;color:#8898aa;text-align:left">
        <span>❤️ ${ch.hp}</span><span>⚡ ${ch.spd}</span>
        <span>💥 ${ch.dmg}</span><span>🎯 ${ch.range}</span>
      </div>
      <div style="margin-top:6px;font-size:9px;background:${ch.color}22;border:1px solid ${ch.color}44;border-radius:4px;padding:3px 6px;color:${ch.color}">⭐ ${ch.special}</div>
    `;
    card.onclick=()=>{
      selected=ch.id;
      document.querySelectorAll('.char-card').forEach(c=>{c.style.borderColor=c.dataset.color+'66';c.style.boxShadow='none';});
      card.style.borderColor=ch.color;
      card.style.boxShadow=`0 0 20px ${ch.color}66`;
      document.getElementById('start-btn').style.display='block';
    };
    card.dataset.color=ch.color;
    grid.appendChild(card);
  });

  window.startGame=()=>{
    if(!selected) return;
    screen.style.display='none';
    hudTop.style.display='flex';
    joyZone.style.display='block';
    document.getElementById('hud-emoji').textContent=CHARS.find(c=>c.id===selected).emoji;
    document.getElementById('hud-name').textContent=CHARS.find(c=>c.id===selected).name;
    initGame(selected);
    G.state='playing';
  };
}

function showUpgradeScreen(upgrades){
  screen.innerHTML='';
  screen.style.background='rgba(0,0,0,0.88)';
  screen.style.display='flex';
  joyZone.style.display='none';

  const s=document.createElement('div');
  s.style.cssText='text-align:center;padding:20px;max-width:380px;width:100%';
  s.innerHTML=`
    <div class="bebas" style="font-size:42px;color:#8844ff;letter-spacing:4px;text-shadow:0 0 20px #8844ff">LEVEL UP!</div>
    <div style="font-size:12px;color:#5a7090;letter-spacing:3px;margin-bottom:24px">LEVEL ${G.level} — CHOOSE AN UPGRADE</div>
    <div id="upg-list" style="display:flex;flex-direction:column;gap:12px"></div>
  `;
  screen.appendChild(s);

  const list=s.querySelector('#upg-list');
  upgrades.forEach(u=>{
    const btn=document.createElement('button');
    btn.style.cssText=`background:linear-gradient(135deg,#0d1117,#161b22);border:2px solid #8844ff55;border-radius:10px;padding:14px 18px;cursor:pointer;text-align:left;width:100%;transition:border .15s;pointer-events:all`;
    btn.innerHTML=`
      <div style="display:flex;align-items:center;gap:12px">
        <span style="font-size:28px">${u.icon}</span>
        <div>
          <div class="bebas" style="font-size:20px;letter-spacing:2px;color:#fff">${u.name}</div>
          <div style="font-size:13px;color:#8898aa">${u.desc}</div>
        </div>
      </div>
    `;
    btn.onpointerdown=()=>btn.style.borderColor='#8844ff';
    btn.onclick=()=>{
      u.apply(G.player);
      screen.style.display='none';
      joyZone.style.display='block';
      G.state='playing';
    };
    list.appendChild(btn);
  });
}

function showWaveTransition(){
  screen.innerHTML='';
  screen.style.background='rgba(0,0,0,0.75)';
  screen.style.display='flex';
  joyZone.style.display='none';

  const isBoss = G.wave%5===0;
  const s=document.createElement('div');
  s.style.cssText='text-align:center;animation:popIn .3s ease-out';
  s.innerHTML=`
    <div class="bebas" style="font-size:56px;color:${isBoss?'#ff2233':'#4488ff'};letter-spacing:4px;text-shadow:0 0 30px ${isBoss?'#ff2233':'#4488ff'}">${isBoss?'⚠️ BOSS ⚠️':'WAVE '+(G.wave)}</div>
    <div style="font-size:14px;color:#5a7090;letter-spacing:3px;margin-top:6px">${isBoss?'ELITE THREAT INCOMING':'PREPARE FOR BATTLE'}</div>
    <div style="font-size:13px;color:#ffcc00;margin-top:8px">Score: ${G.score.toLocaleString()}</div>
  `;
  screen.appendChild(s);

  setTimeout(()=>{
    screen.style.display='none';
    joyZone.style.display='block';
    G.state='playing';
    startWave();
  }, isBoss?2200:1600);
}

function showBossIntro(name){
  // brief flash
  const div=document.createElement('div');
  div.style.cssText='position:fixed;top:0;left:0;right:0;z-index:50;text-align:center;padding:16px;background:linear-gradient(to bottom,#ff223344,transparent);pointer-events:none';
  div.innerHTML=`<div class="bebas" style="font-size:28px;color:#ff2233;letter-spacing:4px;text-shadow:0 0 20px #ff2233">BOSS: ${name}</div>`;
  document.body.appendChild(div);
  setTimeout(()=>div.remove(),3000);
}

function showDead(){
  screen.innerHTML='';
  screen.style.background='rgba(0,0,0,0.9)';
  screen.style.display='flex';
  joyZone.style.display='none';

  const s=document.createElement('div');
  s.style.cssText='text-align:center;padding:20px;max-width:360px;width:100%';
  s.innerHTML=`
    <div class="bebas" style="font-size:62px;color:#ff2233;letter-spacing:4px;text-shadow:0 0 40px #ff2233;animation:pulse 1.5s infinite">YOU DIED</div>
    <div style="font-size:13px;color:#5a7090;margin:6px 0 20px;letter-spacing:2px">The city needed you.</div>
    <div style="font-size:12px;color:#5a7090;letter-spacing:2px">FINAL SCORE</div>
    <div class="bebas" style="font-size:56px;color:#ffcc00;letter-spacing:3px;text-shadow:0 0 20px #ffcc0088">${G.score.toLocaleString()}</div>
    <div style="font-size:13px;color:#5a7090;margin-bottom:6px">WAVE ${G.wave} • LEVEL ${G.level}</div>
    <div style="display:flex;gap:12px;margin-top:24px;justify-content:center">
      <button class="btn" style="border-color:#ff2233;color:#ff2233" onclick="showMenu()">MENU</button>
      <button class="btn" style="border-color:#4488ff;color:#4488ff" onclick="window.startGame&&window.startGame(),G.char&&initGame(G.char.id),hudTop.style.display='flex',joyZone.style.display='block',screen.style.display='none'">RETRY</button>
    </div>
  `;
  // Retry properly
  s.querySelector('.btn:last-child').onclick=()=>{
    initGame(G.char.id);
    screen.style.display='none';
    joyZone.style.display='block';
    G.state='playing';
  };
  screen.appendChild(s);
}

// ── JOYSTICK ─────────────────────────────────────────────────
const joystickDir={x:0,y:0};
const knob=document.getElementById('joystick-knob');
const jBase=document.getElementById('joystick-base');
let joyTouch=null;
const MAX_R=38;

joyZone.addEventListener('touchstart',e=>{
  e.preventDefault();
  joyTouch=e.changedTouches[0].identifier;
},{ passive:false });

window.addEventListener('touchmove',e=>{
  if(joyTouch===null) return;
  e.preventDefault();
  for(const t of e.changedTouches){
    if(t.identifier!==joyTouch) continue;
    const rect=jBase.getBoundingClientRect();
    const cx=rect.left+rect.width/2;
    const cy=rect.top+rect.height/2;
    let dx=t.clientX-cx, dy=t.clientY-cy;
    const d=Math.hypot(dx,dy);
    if(d>MAX_R){dx=dx/d*MAX_R;dy=dy/d*MAX_R;}
    knob.style.left=(38+dx)+'px';
    knob.style.top=(38+dy)+'px';
    joystickDir.x=dx/MAX_R;
    joystickDir.y=dy/MAX_R;
  }
},{ passive:false });

window.addEventListener('touchend',e=>{
  for(const t of e.changedTouches){
    if(t.identifier===joyTouch){
      joyTouch=null;
      knob.style.left='38px'; knob.style.top='38px';
      joystickDir.x=0; joystickDir.y=0;
    }
  }
});

// ── KEYBOARD (desktop) ───────────────────────────────────────
const keys={};
window.addEventListener('keydown',e=>keys[e.key]=true);
window.addEventListener('keyup',e=>keys[e.key]=false);
setInterval(()=>{
  if(G.state!=='playing') return;
  let x=0,y=0;
  if(keys['ArrowLeft']||keys['a']) x=-1;
  if(keys['ArrowRight']||keys['d']) x=1;
  if(keys['ArrowUp']||keys['w']) y=-1;
  if(keys['ArrowDown']||keys['s']) y=1;
  const d=Math.hypot(x,y)||1;
  joystickDir.x=x/d; joystickDir.y=y/d;
},16);

// ── START ────────────────────────────────────────────────────
showMenu();
requestAnimationFrame(loop);
</script>

